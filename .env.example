# Daily Paper Reader local debugging environment variable template
# Copy to `.env` and fill in the real values; `.env` is ignored by `.gitignore` and will not be synced to GitHub.

# ===== Basic operation =====
# Can fix a local run date for reproducible archive paths; leave blank to use today's UTC date.
# DPR_RUN_DATE=20260521

# If you need to temporarily use a different config file, you can point to a local private YAML; leave blank to read `config.yaml`.
# DPR_CONFIG_FILE=config.local.yaml

# ===== LLM / summary model =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Variable names compatible with the summary chain; if not filled, most scripts will fall back to DEEPSEEK_*.
SUMMARY_API_KEY=
SUMMARY_BASE_URL=
SUMMARY_MODEL=
LLM_PRIMARY_BASE_URL=

# ===== Reranker =====
# public-zwwen-rerank / local-qwen3-0.6b / siliconflow-qwen3-0.6b
RERANK_PROFILE=public-zwwen-rerank
RERANK_PROVIDER=public_zwwen
LOCAL_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_API_KEY=
RERANK_API_BASE_URL=https://zwwen.online/rerank
SILICONFLOW_API_KEY=
SILICONFLOW_RERANK_URL=

# Public embedding / rerank service; if you need a private service, you can override it in your local `.env`.
DPR_EMBED_API_URL=https://zwwen.online/embed
DPR_EMBED_API_KEY=
# By default, local Torch models are not automatically installed/loaded; only enable this if remote embedding is unavailable and requirements-local-models.txt is installed.
DPR_EMBED_ALLOW_LOCAL_FALLBACK=0
PUBLIC_RERANK_API_KEY=
PUBLIC_RERANK_API_BASE_URL=https://zwwen.online/rerank

# ===== Supabase local maintenance/sync =====
# When doing read-only retrieval, usually the publishable/anon key in config.yaml is sufficient.
# When executing maintain/sync.py or cleanup.py, fill in the service key in your local `.env`, never commit.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SCHEMA=public
SUPABASE_BACKEND_KEY=arxiv
SUPABASE_PAPERS_TABLE=arxiv_papers
SUPABASE_BM25_RPC=match_arxiv_papers_bm25
SUPABASE_VECTOR_RPC=match_arxiv_papers
SUPABASE_VECTOR_RPC_EXACT=match_arxiv_papers_exact
SUPABASE_SYNC_TABLE=arxiv_sync_status

# Control local arXiv Supabase retrieval开关；不填则沿用 config.yaml。
# DPR_ARXIV_ENABLED=1
# DPR_ARXIV_USE_BM25_RPC=1
# DPR_ARXIV_USE_VECTOR_RPC=1

# ===== Multi-source backend local override examples =====
# These variables only override the local process environment, not writing back to config.yaml.
# DPR_ENABLE_BIORXIV_BACKEND=1
# DPR_BIORXIV_URL=
# DPR_BIORXIV_ANON_KEY=
# DPR_BIORXIV_PAPERS_TABLE=biorxiv_papers
# DPR_BIORXIV_BM25_RPC=match_biorxiv_papers_bm25
# DPR_BIORXIV_VECTOR_RPC=match_biorxiv_papers_exact

# ===== OpenReview optional login =====
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=

# ===== Debug switch =====
# Set to 1 to disable automatic loading of `.env`.
# DPR_DISABLE_DOTENV=1
# Specify other env file paths.
# DPR_DOTENV_PATH=/absolute/path/to/.env.local
